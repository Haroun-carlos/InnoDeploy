# Traefik ACME (required for Let's Encrypt in production)
TRAEFIK_ACME_EMAIL=admin@example.com

# Domain routed to backend API
TRAEFIK_API_HOST=api.localhost

# Domain routed to websocket gateway
TRAEFIK_WS_HOST=ws.localhost

# Domain routed to dashboard app
TRAEFIK_APP_HOST=app.localhost

# Dashboard build-time public env (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_WS_URL=http://localhost:7070

# Optional: turn on Traefik dashboard
TRAEFIK_DASHBOARD_ENABLED=false
TRAEFIK_LOG_LEVEL=INFO

# Rate limiting
TRAEFIK_RATE_LIMIT_AVERAGE=120
TRAEFIK_RATE_LIMIT_BURST=60

# Comma-separated CIDR list for ingress allowlist
TRAEFIK_IP_ALLOWLIST=0.0.0.0/0,::/0

# Optional staging basic auth. Format user:hashed_password
# Example hash command:
#   htpasswd -nb admin strongpassword
TRAEFIK_STAGING_BASIC_AUTH_USERS=

# Set any non-empty value to append the basic auth middleware
# Example: TRAEFIK_ENABLE_STAGING_AUTH=1
TRAEFIK_ENABLE_STAGING_AUTH=

# MinIO object store credentials (used by backend workers)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
