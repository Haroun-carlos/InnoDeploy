{
  "name": "innodeploy-backend",
  "version": "1.0.0",
  "description": "InnoDeploy — DevOps SaaS Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "kill-port 5000 && nodemon src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest tests/unit --forceExit",
    "test:integration": "jest tests/integration --forceExit --detectOpenHandles",
    "start:ws": "node src/services/websocketGateway.js",
    "start:pipeline-runner": "node src/workers/pipelineRunnerMain.js",
    "start:deploy-worker": "node src/workers/deployWorkerMain.js"
  },
  "keywords": [
    "devops",
    "saas",
    "cicd",
    "innodeploy"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1014.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.0",
    "cors": "^2.8.5",
    "dockerode": "^4.0.10",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.0",
    "morgan": "^1.10.0",
    "node-pty": "^1.1.0",
    "nodemailer": "^8.0.3",
    "redis": "^4.7.0",
    "ssh2": "^1.17.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "kill-port": "^2.0.1",
    "nodemon": "^3.1.4",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
