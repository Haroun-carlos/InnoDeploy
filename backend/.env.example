# ── Server ─────────────────────────────────────────────────
PORT=5000

# ── MongoDB ────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/innodeploy

# ── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Secrets (replace with strong random strings in production) ──
JWT_SECRET=change_me_access_secret_32chars
JWT_REFRESH_SECRET=change_me_refresh_secret_32chars

# ── Client URL (CORS) ─────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── OAuth Configuration ───────────────────────────────────
API_BASE_URL=http://localhost:5000/api
OAUTH_REDIRECT_URL=http://localhost:3000/auth/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ── Pipeline Runner ───────────────────────────────────────
PIPELINE_RUNNER_ENABLED=false
PIPELINE_RUNNER_CONCURRENCY=1
PIPELINE_STEP_TIMEOUT_MS=600000
PIPELINE_STEP_RETRIES=0
PIPELINE_QUEUE_NAME=pipeline-jobs
PIPELINE_QUEUE_KEY=queue:pipeline
PIPELINE_EVENTS_CHANNEL=pipeline:events
PIPELINE_LOGS_CHANNEL=pipeline:logs
PIPELINE_LOGS_CHANNEL_PREFIX=pipeline:logs:
PIPELINE_STAGE_IMAGE=node:20-alpine

# ── Deploy Worker ────────────────────────────────────────
DEPLOY_WORKER_ENABLED=false
DEPLOY_WORKER_CONCURRENCY=1
DEPLOY_STEP_TIMEOUT_MS=480000
DEPLOY_QUEUE_NAME=deploy-jobs
DEPLOY_QUEUE_KEY=queue:deploy
DEPLOY_EVENTS_CHANNEL=deploy:events
DEPLOY_CANARY_TRAFFIC_PERCENT=10
DEPLOY_CANARY_WINDOW_MS=300000
DEPLOY_CANARY_ERROR_RATE_THRESHOLD=0.02
DEPLOY_BLUE_GREEN_DRAIN_MS=60000
DEPLOY_HEALTHCHECK_INTERVAL_MS=5000
DEPLOY_HEALTHCHECK_ATTEMPTS=5
TRAEFIK_ROUTE_EVENTS_CHANNEL=traefik:route-events

# ── Log Collector ────────────────────────────────────────
LOG_COLLECTOR_ENABLED=false
LOG_COLLECTOR_SOURCE=docker
LOG_COLLECTOR_SINCE_SECONDS=5
LOG_RETENTION_DAYS=30
LOG_SEARCH_MODE=text
LOG_ATLAS_INDEX=logs_index
LOG_MAX_MESSAGE_LENGTH=8000

# ── Monitor Worker ───────────────────────────────────────
MONITOR_WORKER_ENABLED=false
MONITOR_INTERVAL_MS=15000
MONITOR_HTTP_TIMEOUT_MS=4000
MONITOR_DOCKER_STATS_TIMEOUT_MS=5000
MONITOR_LOG_TAIL_LINES=20
MONITOR_DEFAULT_HEALTH_PATH=/health
MONITOR_STREAM_CHANNEL=monitoring:stream
MONITOR_PROJECT_CHANNEL_PREFIX=monitoring:project:

# ── WebSocket Gateway ────────────────────────────────────
WS_PORT=7070
WS_PATH=/ws

# ── Object Store (S3-compatible / MinIO) ────────────────
OBJECT_STORE_ENABLED=false
OBJECT_STORE_ENDPOINT=http://minio:9000
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_ACCESS_KEY=minioadmin
OBJECT_STORE_SECRET_KEY=minioadmin
OBJECT_STORE_BUCKET=innodeploy-artifacts

# ── Email Configuration (SMTP) ──────────────────────────
# Required for: User registration emails, password reset, notifications
# Gmail example: smtp.gmail.com, port 587, enable "Less secure apps"
# Or use an app-specific password for Gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=example@gmail.com
SMTP_PASS=examplepassword
SMTP_FROM=noreply@innodeploy.com

# ── Slack Webhook (Notifications) ───────────────────────
# Get webhook URL from: https://api.slack.com/apps
# Create app → Incoming Webhooks → Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/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

# ── Discord Webhook (Notifications) ─────────────────────
# Get webhook URL from Discord:
# Right-click channel → Edit → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/1492008973019123753/T6LgQhqpBABiwxfYk7TCMN2d2Mqj66AZZnzSp3bRgGiFcdKb3FqoPxXs6pfbgaV-cyuv

# ── Telegram Notifications ──────────────────────────────
# Get bot token: Chat with @BotFather on Telegram, create bot, copy token
# Get chat ID: Add bot to group/channel, send `/my_id` to bot, copy number
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Monitoring & Alerts ─────────────────────────────────
ALERT_AUTO_RESTART_ON_MEMORY_EXHAUSTION=true
NOTIFICATION_TIMEOUT_MS=5000
